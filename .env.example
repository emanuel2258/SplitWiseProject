# CSV File Configuration
# Path to the directory containing your expense CSV file
CSV_READ_PATH=/path/to/your/expenses/

# Name of your expense CSV file (e.g., expenses_march_2026.csv)
CSV_READ_FILE_NAME=expenses.csv

# Path where the modified CSV file will be saved
CSV_WRITE_PATH=/path/to/output/

# Splitwise API Configuration
# Your Splitwise API key (get it from https://secure.splitwise.com/apps)
SPLITWISE_API_KEY=your_api_key_here

# Your Splitwise group ID (find it in the URL when viewing your group)
SPLITWISE_GROUP_ID=your_group_id_here